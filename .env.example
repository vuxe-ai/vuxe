# Vuxe Backend Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgres://vuxe:vuxe@localhost:5432/vuxe

# Server
HOST=0.0.0.0
PORT=8080

# Auth provider: "clerk" or "oidc"
AUTH_PROVIDER=clerk

# Clerk (used when AUTH_PROVIDER=clerk)
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
CLERK_AUTHORIZED_PARTIES=https://api.clerk.com

# OIDC (used when AUTH_PROVIDER=oidc)
OIDC_ISSUER_URL=https://your-oidc-provider.com
OIDC_CLIENT_ID=vuxe
OIDC_CLIENT_SECRET=changeme

# Rust log level
RUST_LOG=info,vuxe_backend=debug

# JWT signing secret for session tokens
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-random-secret
